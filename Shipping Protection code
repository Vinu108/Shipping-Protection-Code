<div class="protection-box">
    <div class="left">
      <span class="icon">
        <img src="{{ shipping_product.featured_image | image_url }}" alt="{{ shipping_product.title }}">
      </span>

      <div>
        <h5>{{ shipping_product.title }}</h5>
        <small>{{ shipping_product.description }}</small>
      </div>
    </div>

    <label class="switch">
      <input
        type="checkbox"
        id="packageProtection"
        data-variant-id="{{ shipping_product.variants.first.id }}"
        {% if protection_in_cart %}checked{% endif %}
      >
      <span class="slider"></span>
    </label>
  </div>
.protection-box{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px;
  border-top:1px solid #eee;
}

.protection-box .left {
    display: grid;
    gap: 10px;
    align-items: center;
    grid-template-columns: 50px 1fr;
}

.icon{
  font-size:26px;
}

.switch{
  position:relative;
  width:50px;
  height:26px;
}

.switch input{
  display:none;
}

.slider{
  position:absolute;
  inset:0;
  background:#ddd;
  border-radius:50px;
  cursor:pointer;
}

.slider:before{
  content:'';
  position:absolute;
  width:20px;
  height:20px;
  left:3px;
  top:3px;
  background:#fff;
  border-radius:50%;
  transition:.3s;
}

.switch input:checked + .slider:before{
  transform:translateX(24px);
}

.cart-footer{
  padding:15px;
  border-top:1px solid #eee;
}

.subtotal{
  display:flex;
  justify-content:space-between;
  margin-bottom:15px;
  font-size:20px;
}

.checkout-btn{
  display:block;
  text-align:center;
  background:#000;
  color:#fff;
  text-decoration:none;
  padding:16px;
  border-radius:40px;
  font-weight:700;
}

.empty_cart_wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}
body:has(#custom-cart-drawer:not([style*="display: none"])) {
  overflow: auto;
}
body:has(#custom-cart-drawer[style*="display: block"]) {
  overflow: hidden;
}
.fbt-section h4 {
    margin: 0 0 10px;
}
$(document).on('change', '#packageProtection', function () {
    const variantId = $(this).data('variant-id');

    if ($(this).is(':checked')) {

        // Add product
        $.ajax({
            url: '/cart/add.js',
            type: 'POST',
            dataType: 'json',
            data: {
                id: variantId,
                quantity: 1
            },
            success: function () {
                console.log('Protection added');

                // Refresh drawer if needed
                refreshCartDrawer();
            }
        });

    } else {

        // Get cart first
        $.getJSON('/cart.js', function (cart) {

            const item = cart.items.find(item => item.variant_id == variantId);

            if (!item) return;

            // Remove product
            $.ajax({
                url: '/cart/change.js',
                type: 'POST',
                dataType: 'json',
                data: {
                    id: item.key,      // line item key
                    quantity: 0
                },
                success: function () {
                    console.log('Protection removed');

                    // Refresh drawer if needed
                    refreshCartDrawer();
                }
            });

        });

    }
});
